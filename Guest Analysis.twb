          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column datatype='real' default-format='p0.00%' name='[Calculation3]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1124821839675393] / TOTAL([Calculation_1124821839675393])'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column datatype='real' default-format='p0.00%' name='[Calculation4]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1124821839675393] / TOTAL([Calculation_1124821839675393])'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='rank room type' datatype='integer' name='[Calculation_0149555926020096]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Rank Room Type&#13;&#10;RANK(SUM([Calculation_1124821839941634]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='top room type' datatype='string' name='[Calculation_0149555926192129]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF RANK(SUM([Calculation_1124821839941634]))=1&#13;&#10;THEN ATTR([Room_Type])&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='avg rating' datatype='real' name='[Calculation_0149555927539716]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Calculation_1124821847253007])' />
      </column>
      <column caption='Top room' datatype='string' name='[Calculation_0149555929366537]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF&#13;&#10;{ FIXED [Room_Type] : SUM([Calculation_1124821839941634]) }&#13;&#10;=&#13;&#10;{ FIXED : MAX({ FIXED [Room_Type] : SUM([Calculation_1124821839941634]) }) }&#13;&#10;&#13;&#10;THEN [Room_Type]&#13;&#10;END' />
      </column>
      <column caption='Tc' datatype='real' name='[Calculation_0149555930238987]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Country] : SUM([Calculation_1124821839941634]) }' />
      </column>
      <column caption='HRCT' datatype='string' name='[Calculation_0149555930345484]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF&#13;&#10;{ FIXED [Country] : SUM([Calculation_1124821839941634]) }&#13;&#10;=&#13;&#10;{ FIXED : MAX({ FIXED [Country] : SUM([Calculation_1124821839941634]) }) }&#13;&#10;&#13;&#10;THEN [Country]&#13;&#10;END' />
      </column>
      <column caption='HRCS' datatype='real' name='[Calculation_0149555930566669]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED :&#13;&#10;MAX({ FIXED [Country] : SUM([Calculation_1124821839941634]) })&#13;&#10;}&#13;&#10;&#13;&#10;/&#13;&#10;&#13;&#10;{ FIXED : SUM([Calculation_1124821839941634]) }' />
      </column>
      <column caption='HRBC' datatype='string' name='[Calculation_0149555933552657]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF&#13;&#10;{ FIXED [Booking_Channel] : SUM([Calculation_1124821839941634]) }&#13;&#10;=&#13;&#10;{ FIXED :&#13;&#10;MAX(&#13;&#10;    { FIXED [Booking_Channel] : SUM([Calculation_1124821839941634]) }&#13;&#10;)&#13;&#10;}&#13;&#10;THEN&#13;&#10;[Booking_Channel]&#13;&#10;END' />
      </column>
      <column caption='one' datatype='integer' name='[Calculation_0149555937038354]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1' />
      </column>
      <column caption='Total Revenue' datatype='real' name='[Calculation_0149555940626453]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Room_Fare])+SUM([Additional_Spend])' />
      </column>
      <column caption='TR' datatype='real' name='[Calculation_0149555941933079]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : SUM([Calculation_1124821839941634]) }' />
      </column>
      <column caption='Age Group' datatype='string' name='[Calculation_0149555956973592]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Guest_Age] &lt; 20 THEN &quot;Under 20&quot;&#13;&#10;&#13;&#10;ELSEIF [Guest_Age] &gt;= 20 AND [Guest_Age] &lt;= 29 THEN &quot;20–29&quot;&#13;&#10;&#13;&#10;ELSEIF [Guest_Age] &gt;= 30 AND [Guest_Age] &lt;= 39 THEN &quot;30–39&quot;&#13;&#10;&#13;&#10;ELSEIF [Guest_Age] &gt;= 40 AND [Guest_Age] &lt;= 49 THEN &quot;40–49&quot;&#13;&#10;&#13;&#10;ELSEIF [Guest_Age] &gt;= 50 AND [Guest_Age] &lt;= 59 THEN &quot;50–59&quot;&#13;&#10;&#13;&#10;ELSE &quot;60+&quot;&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Age Group Order' datatype='integer' name='[Calculation_0149555957084185]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Calculation_0149555956973592]&#13;&#10;&#13;&#10;WHEN &quot;Under 20&quot; THEN 1&#13;&#10;WHEN &quot;20–29&quot; THEN 2&#13;&#10;WHEN &quot;30–39&quot; THEN 3&#13;&#10;WHEN &quot;40–49&quot; THEN 4&#13;&#10;WHEN &quot;50–59&quot; THEN 5&#13;&#10;WHEN &quot;60+&quot; THEN 6&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Guest%' datatype='real' name='[Calculation_0149555957379098]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([Guest_Age]) / TOTAL(COUNT([Guest_Age]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Highlight' datatype='string' name='[Calculation_0149555959685147]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF&#13;&#10;{ FIXED [Calculation_0149555956973592] : COUNT([Guest_Age]) }&#13;&#10;=&#13;&#10;{ FIXED :&#13;&#10;MAX(&#13;&#10;    { FIXED [Calculation_0149555956973592] : COUNT([Guest_Age]) }&#13;&#10;)&#13;&#10;}&#13;&#10;THEN &quot;Highest&quot;&#13;&#10;&#13;&#10;ELSE &quot;Others&quot;&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Label' datatype='string' name='[Calculation_0149555960242204]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF&#13;&#10;{ FIXED [Calculation_0149555956973592] : COUNT([Guest_Age]) }&#13;&#10;=&#13;&#10;{ FIXED :&#13;&#10;MAX(&#13;&#10;    { FIXED [Calculation_0149555956973592] : COUNT([Guest_Age]) }&#13;&#10;)&#13;&#10;}&#13;&#10;THEN &quot;⭐ Largest Guest Segment&quot;&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='AVG(0)' datatype='real' name='[Calculation_0149555964829727]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(0)' />
      </column>
      <column caption='TCM' datatype='string' name='[Calculation_0149555976126496]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF&#13;&#10;{ FIXED [Country] : SUM([Calculation_1124821839941634]) }&#13;&#10;=&#13;&#10;{ FIXED :&#13;&#10;MAX(&#13;&#10;    { FIXED [Country] : SUM([Calculation_1124821839941634]) }&#13;&#10;)&#13;&#10;}&#13;&#10;THEN &quot;Top Market&quot;&#13;&#10;&#13;&#10;ELSE &quot;Other Markets&quot;&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Feedback numeric' datatype='real' name='[Calculation_0149555980234785]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Calculation_1124821847253007])' />
      </column>
      <column caption='Total Guest' datatype='integer' name='[Calculation_1124821839675393]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([Guest_ID])' />
      </column>
      <column caption='Customer Revenue' datatype='real' name='[Calculation_1124821839941634]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Guest_ID] :&#13;&#10;&#13;&#10;SUM([Room_Fare]+[Additional_Spend])&#13;&#10;&#13;&#10;}' />
      </column>
      <column caption='Avg revenue by contry' datatype='real' name='[Calculation_1124821840166915]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Country] :&#13;&#10;&#13;&#10;AVG([Room_Fare]+[Additional_Spend])&#13;&#10;&#13;&#10;}' />
      </column>
      <column caption='Revenue by booking channel' datatype='real' name='[Calculation_1124821840343044]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Booking_Channel] :&#13;&#10;&#13;&#10;SUM([Room_Fare]+[Additional_Spend])&#13;&#10;&#13;&#10;}' />
      </column>
      <column caption='Avg Revenue' datatype='real' name='[Calculation_1124821843484679]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : AVG([Calculation_1124821839941634]) }' />
      </column>
      <column caption='Avg night stayed' datatype='real' name='[Calculation_1124821843689480]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : AVG([Nights_Stayed]) }' />
      </column>
      <column caption='customer segment' datatype='string' name='[Calculation_1124821843779593]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1124821839941634] &gt;= [Calculation_1124821843484679]&#13;&#10;AND [Nights_Stayed] &gt;= [Calculation_1124821843689480] THEN&#13;&#10;&#13;&#10;&quot;VIP Guest&quot;&#13;&#10;&#13;&#10;ELSEIF [Calculation_1124821839941634] &gt;= [Calculation_1124821843484679] THEN&#13;&#10;&#13;&#10;&quot;Premium Guest&quot;&#13;&#10;&#13;&#10;ELSEIF [Nights_Stayed] &gt;= [Calculation_1124821843689480] THEN&#13;&#10;&#13;&#10;&quot;Loyal Guest&quot;&#13;&#10;&#13;&#10;ELSE&#13;&#10;&#13;&#10;&quot;Budget Guest&quot;&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Avg additional spend' datatype='real' name='[Calculation_1124821845213196]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Additional_Spend])' />
      </column>
      <column caption='feedback score' datatype='integer' name='[Calculation_1124821847253007]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Feedback_Rating]&#13;&#10;&#13;&#10;WHEN &quot;Poor&quot; THEN 1&#13;&#10;&#13;&#10;WHEN &quot;Average&quot; THEN 2&#13;&#10;&#13;&#10;WHEN &quot;Good&quot; THEN 3&#13;&#10;&#13;&#10;WHEN &quot;Excellent&quot; THEN 4&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='rating' datatype='string' name='[Calculation_1124821847388176]' role='measure' type='nominal'>
        <calculation class='tableau' formula='STR(ROUND(AVG([Calculation_1124821847253007]),0)) + &quot; / 4&quot;' />
      </column>
      <column caption='Avg of feed back' datatype='real' name='[Calculation_1124821850116116]' role='measure' type='quantitative'>
