          <formatted-text>
            <run fontalignment='1' fontcolor='#303030' fontname='Tableau Bold' fontsize='12'><![CDATA[<[federated.17t2k4l07sbibc1bemakn0e4y0nb].[sum:Calculation_1124821858218011:qk]> / 4]]></run>
