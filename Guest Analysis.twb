            <column caption='Customer Revenue' datatype='real' name='[Calculation_1124821839941634]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [Guest_ID] :&#13;&#10;&#13;&#10;SUM([Room_Fare]+[Additional_Spend])&#13;&#10;&#13;&#10;}' />
            </column>
            <column caption='Avg night stayed' datatype='real' name='[Calculation_1124821843689480]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : AVG([Nights_Stayed]) }' />
            </column>
            <column caption='feedback score' datatype='integer' name='[Calculation_1124821847253007]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Feedback_Rating]&#13;&#10;&#13;&#10;WHEN &quot;Poor&quot; THEN 1&#13;&#10;&#13;&#10;WHEN &quot;Average&quot; THEN 2&#13;&#10;&#13;&#10;WHEN &quot;Good&quot; THEN 3&#13;&#10;&#13;&#10;WHEN &quot;Excellent&quot; THEN 4&#13;&#10;&#13;&#10;END' />
            </column>
            <column caption='Avg of feed back' datatype='real' name='[Calculation_1124821850116116]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG([Calculation_1124821847253007])' />
            </column>
            <column caption='Revenue Dimension' datatype='string' name='[Calculation_1429936610799619]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 1429936607739904]&#13;&#10;&#13;&#10;WHEN &quot;Country&quot; THEN [Country]&#13;&#10;&#13;&#10;WHEN &quot;Room_Type&quot; THEN [Room_Type]&#13;&#10;&#13;&#10;WHEN &quot;Booking_Channel&quot; THEN [Booking_Channel]&#13;&#10;&#13;&#10;END' />
            </column>
            <column caption='{[Total Guest]}' datatype='integer' name='[Calculation_1429936673869837]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{[Calculation_1124821839675393]}' />
            </column>
            <column caption='Guest Share%' datatype='real' name='[Calculation_1429936674295822]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD([Guest_ID])&#13;&#10;/&#13;&#10;TOTAL(COUNTD([Guest_ID]))'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Performance Volume' datatype='string' name='[Calculation_1429936674537488]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF COUNTD([Guest_ID]) &gt;= WINDOW_AVG(COUNTD([Guest_ID])) THEN&#13;&#10;&#13;&#10;&quot;High Guest Volume&quot;&#13;&#10;&#13;&#10;ELSE&#13;&#10;&#13;&#10;&quot;Low Guest Volume&quot;&#13;&#10;&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Recommendation' datatype='string' name='[Calculation_1429936674652177]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF COUNTD([Guest_ID]) &gt;= WINDOW_AVG(COUNTD([Guest_ID])) THEN&#13;&#10;&#13;&#10;&quot;Maintain marketing efforts and improve guest loyalty.&quot;&#13;&#10;&#13;&#10;ELSE&#13;&#10;&#13;&#10;&quot;Increase promotions and investigate demand.&quot;&#13;&#10;&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column datatype='string' name='[Country]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
            <column caption='Dynamic Title g' datatype='string' name='[Dynamic Title (copy)_1429936677703700]' role='dimension' type='nominal'>
