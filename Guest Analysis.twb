          <datasource-dependencies datasource='Parameters'>
            <column alias='Booking Channel' caption='Revenue' datatype='string' name='[Parameter 1429936607739904]' param-domain-type='list' role='measure' type='nominal' value='&quot;Booking_Channel&quot;'>
