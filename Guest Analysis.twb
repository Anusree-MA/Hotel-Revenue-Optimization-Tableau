    <worksheet name='Booking channel'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#777777' fontname='Tableau Bold' fontsize='8'>&lt;</run>
            <run fontcolor='#777777' fontname='Tableau Bold' fontsize='8'>[Parameters].[Parameter 1429936684539928]</run>
            <run fontcolor='#777777' fontname='Tableau Bold' fontsize='8'>&gt;  by Booking Channel</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='hotel_guest_stays' name='federated.17t2k4l07sbibc1bemakn0e4y0nb' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Performance Metric' datatype='string' name='[Parameter 1429936684539928]' param-domain-type='list' role='measure' type='nominal' value='&quot;Revenue&quot;'>
              <calculation class='tableau' formula='&quot;Revenue&quot;' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.17t2k4l07sbibc1bemakn0e4y0nb'>
            <column caption='Additional Spend' datatype='real' name='[Additional_Spend]' role='measure' type='quantitative' />
            <column caption='Booking Channel' datatype='string' name='[Booking_Channel]' role='dimension' type='nominal' />
            <column caption='Age Group' datatype='string' name='[Calculation_0149555956973592]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Guest_Age] &lt; 20 THEN &quot;Under 20&quot;&#13;&#10;&#13;&#10;ELSEIF [Guest_Age] &gt;= 20 AND [Guest_Age] &lt;= 29 THEN &quot;20–29&quot;&#13;&#10;&#13;&#10;ELSEIF [Guest_Age] &gt;= 30 AND [Guest_Age] &lt;= 39 THEN &quot;30–39&quot;&#13;&#10;&#13;&#10;ELSEIF [Guest_Age] &gt;= 40 AND [Guest_Age] &lt;= 49 THEN &quot;40–49&quot;&#13;&#10;&#13;&#10;ELSEIF [Guest_Age] &gt;= 50 AND [Guest_Age] &lt;= 59 THEN &quot;50–59&quot;&#13;&#10;&#13;&#10;ELSE &quot;60+&quot;&#13;&#10;&#13;&#10;END' />
            </column>
            <column caption='Total Guest' datatype='integer' name='[Calculation_1124821839675393]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD([Guest_ID])' />
            </column>
            <column caption='Customer Revenue' datatype='real' name='[Calculation_1124821839941634]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [Guest_ID] :&#13;&#10;&#13;&#10;SUM([Room_Fare]+[Additional_Spend])&#13;&#10;&#13;&#10;}' />
            </column>
            <column caption='Avg Revenue' datatype='real' name='[Calculation_1124821843484679]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : AVG([Calculation_1124821839941634]) }' />
            </column>
            <column caption='feedback score' datatype='integer' name='[Calculation_1124821847253007]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Feedback_Rating]&#13;&#10;&#13;&#10;WHEN &quot;Poor&quot; THEN 1&#13;&#10;&#13;&#10;WHEN &quot;Average&quot; THEN 2&#13;&#10;&#13;&#10;WHEN &quot;Good&quot; THEN 3&#13;&#10;&#13;&#10;WHEN &quot;Excellent&quot; THEN 4&#13;&#10;&#13;&#10;END' />
            </column>
            <column caption='Avg of feed back' datatype='real' name='[Calculation_1124821850116116]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG([Calculation_1124821847253007])' />
            </column>
            <column caption='Avg Revenue Tooltip' datatype='real' name='[Calculation_1429936666939401]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='WINDOW_AVG(SUM([Calculation_1124821839941634]))'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Dynamic Measure' datatype='real' name='[Calculation_1429936685060121]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 1429936684539928]&#13;&#10;&#13;&#10;WHEN &quot;Revenue&quot; THEN&#13;&#10;SUM([Calculation_1124821839941634])&#13;&#10;&#13;&#10;WHEN &quot;Average Revenue&quot; THEN&#13;&#10;AVG([Calculation_1124821839941634])&#13;&#10;&#13;&#10;WHEN &quot;Guest Count&quot; THEN&#13;&#10;COUNTD([Guest_ID])&#13;&#10;&#13;&#10;WHEN &quot;Average Rating&quot; THEN&#13;&#10;([Calculation_1124821850116116])&#13;&#10;&#13;&#10;END' />
            </column>
            <column caption='Channel Recommendation' datatype='string' name='[Calculation_1429936687284252]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF SUM([Calculation_1124821839941634]) &gt;= WINDOW_AVG(SUM([Calculation_1124821839941634])) THEN&#13;&#10;&#13;&#10;&quot;Continue investing in this booking channel and strengthen customer retention.&quot;&#13;&#10;&#13;&#10;ELSE&#13;&#10;&#13;&#10;&quot;Review pricing, promotions, and marketing campaigns to improve channel performance.&quot;&#13;&#10;&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Avg Revenue channel' datatype='real' name='[Calculation_1429936690901022]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG([Calculation_1124821839941634])' />
            </column>
            <column datatype='string' name='[Country]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
            <column caption='Feedback Rating' datatype='string' name='[Feedback_Rating]' role='dimension' type='nominal' />
            <column caption='Guest Age' datatype='integer' name='[Guest_Age]' role='measure' type='quantitative' />
