            <column caption='feedback score' datatype='integer' name='[Calculation_1124821847253007]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Feedback_Rating]&#13;&#10;&#13;&#10;WHEN &quot;Poor&quot; THEN 1&#13;&#10;&#13;&#10;WHEN &quot;Average&quot; THEN 2&#13;&#10;&#13;&#10;WHEN &quot;Good&quot; THEN 3&#13;&#10;&#13;&#10;WHEN &quot;Excellent&quot; THEN 4&#13;&#10;&#13;&#10;END' />
            </column>
