      <column caption='Above/ below guest' datatype='string' name='[Above/ below (copy)_1429936675569682]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF ([Calculation_1124821839675393]) &gt;= WINDOW_AVG(([Calculation_1124821839675393])) THEN&#13;&#10;&quot;Above Average&quot;&#13;&#10;ELSE&#13;&#10;&quot;Below Average&quot;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
