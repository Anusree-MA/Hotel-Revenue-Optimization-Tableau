    <worksheet name='Customer Satisfaction- tooltip'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontalignment='1' fontcolor='#1b1b1b' fontname='Tableau Bold'><![CDATA[<[federated.17t2k4l07sbibc1bemakn0e4y0nb].[sum:Calculation_1124821858218011:qk]> / 4]]></run>
            <run fontalignment='1'>Æ&#10;</run>
            <run fontalignment='1' fontname='Tableau Bold' fontsize='12'>Customer Satisfaction Score</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='hotel_guest_stays' name='federated.17t2k4l07sbibc1bemakn0e4y0nb' />
          </datasources>
          <datasource-dependencies datasource='federated.17t2k4l07sbibc1bemakn0e4y0nb'>
            <column caption='feedback score' datatype='integer' name='[Calculation_1124821847253007]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Feedback_Rating]&#13;&#10;&#13;&#10;WHEN &quot;Poor&quot; THEN 1&#13;&#10;&#13;&#10;WHEN &quot;Average&quot; THEN 2&#13;&#10;&#13;&#10;WHEN &quot;Good&quot; THEN 3&#13;&#10;&#13;&#10;WHEN &quot;Excellent&quot; THEN 4&#13;&#10;&#13;&#10;END' />
            </column>
            <column caption='Avg of feed back' datatype='real' name='[Calculation_1124821850116116]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='AVG([Calculation_1124821847253007])' />
            </column>
            <column caption='Excellent %' datatype='real' name='[Calculation_1124821851357205]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(&#13;&#10;IF [Feedback_Rating] = &quot;Excellent&quot; THEN 1 ELSE 0 END&#13;&#10;)&#13;&#10;/COUNT([Guest_ID])' />
            </column>
            <column caption='Good %' datatype='real' name='[Calculation_1124821851463702]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(&#13;&#10;IF [Feedback_Rating] = &quot;Good&quot; THEN 1 ELSE 0 END&#13;&#10;)&#13;&#10;/COUNT([Guest_ID])' />
            </column>
            <column caption='Avg %' datatype='real' name='[Calculation_1124821851533335]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(&#13;&#10;IF [Feedback_Rating] = &quot;Average&quot; THEN 1 ELSE 0 END&#13;&#10;)&#13;&#10;/COUNT([Guest_ID])' />
            </column>
            <column caption='Poor %' datatype='real' name='[Calculation_1124821851594776]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(&#13;&#10;IF [Feedback_Rating] = &quot;Poor&quot; THEN 1 ELSE 0 END&#13;&#10;)&#13;&#10;/COUNT([Guest_ID])' />
            </column>
            <column caption='Satisfaction feedback' datatype='string' name='[Calculation_1124821852155929]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF AVG([Calculation_1124821847253007]) &gt;= 3.5 THEN&#13;&#10;&quot;Excellent Service&quot;&#13;&#10;&#13;&#10;ELSEIF AVG([Calculation_1124821847253007]) &gt;= 3 THEN&#13;&#10;&quot;Good Service&quot;&#13;&#10;&#13;&#10;ELSEIF AVG([Calculation_1124821847253007]) &gt;= 2 THEN&#13;&#10;&quot;Needs Improvement&quot;&#13;&#10;&#13;&#10;ELSE&#13;&#10;&quot;Critical Attention Required&quot;&#13;&#10;END' />
            </column>
            <column caption='{[Avg of feed back]}' datatype='real' name='[Calculation_1124821858218011]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{[Calculation_1124821850116116]}' />
            </column>
            <column caption='Tooltip' datatype='string' name='[Calculation_1124821862903836]' role='dimension' type='nominal'>
