    <worksheet name='Heat map'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#777777' fontname='Tableau Bold' fontsize='8'>Guest Satisfaction by Age Group</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='hotel_guest_stays' name='federated.17t2k4l07sbibc1bemakn0e4y0nb' />
          </datasources>
          <datasource-dependencies datasource='federated.17t2k4l07sbibc1bemakn0e4y0nb'>
            <column caption='Additional Spend' datatype='real' name='[Additional_Spend]' role='measure' type='quantitative' />
            <column caption='Booking Channel' datatype='string' name='[Booking_Channel]' role='dimension' type='nominal' />
            <column caption='Age Group' datatype='string' name='[Calculation_0149555956973592]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Guest_Age] &lt; 20 THEN &quot;Under 20&quot;&#13;&#10;&#13;&#10;ELSEIF [Guest_Age] &gt;= 20 AND [Guest_Age] &lt;= 29 THEN &quot;20–29&quot;&#13;&#10;&#13;&#10;ELSEIF [Guest_Age] &gt;= 30 AND [Guest_Age] &lt;= 39 THEN &quot;30–39&quot;&#13;&#10;&#13;&#10;ELSEIF [Guest_Age] &gt;= 40 AND [Guest_Age] &lt;= 49 THEN &quot;40–49&quot;&#13;&#10;&#13;&#10;ELSEIF [Guest_Age] &gt;= 50 AND [Guest_Age] &lt;= 59 THEN &quot;50–59&quot;&#13;&#10;&#13;&#10;ELSE &quot;60+&quot;&#13;&#10;&#13;&#10;END' />
            </column>
            <column caption='Guest%' datatype='real' name='[Calculation_0149555957379098]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNT([Guest_Age]) / TOTAL(COUNT([Guest_Age]))'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Highlight' datatype='string' name='[Calculation_0149555959685147]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF&#13;&#10;{ FIXED [Calculation_0149555956973592] : COUNT([Guest_Age]) }&#13;&#10;=&#13;&#10;{ FIXED :&#13;&#10;MAX(&#13;&#10;    { FIXED [Calculation_0149555956973592] : COUNT([Guest_Age]) }&#13;&#10;)&#13;&#10;}&#13;&#10;THEN &quot;Highest&quot;&#13;&#10;&#13;&#10;ELSE &quot;Others&quot;&#13;&#10;&#13;&#10;END' />
            </column>
            <column caption='Total Guest' datatype='integer' name='[Calculation_1124821839675393]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD([Guest_ID])' />
            </column>
            <column caption='Customer Revenue' datatype='real' name='[Calculation_1124821839941634]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [Guest_ID] :&#13;&#10;&#13;&#10;SUM([Room_Fare]+[Additional_Spend])&#13;&#10;&#13;&#10;}' />
            </column>
            <column caption='Avg night stayed' datatype='real' name='[Calculation_1124821843689480]' role='measure' type='quantitative'>
